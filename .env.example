# NextAuth Configuration
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://127.0.0.1:3000

# Spotify OAuth
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
# Spotify Web API base (used by serverActions.ts)
SPOTIFY_API_BASE_URL=https://api.spotify.com/v1

# Cloudinary (image uploads)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your-unsigned-preset
# Server-only Cloudinary credentials (used by /api/cloudinary/delete)
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Google Maps (server-only, used by /api/places/autocomplete)
GOOGLE_MAPS_API_KEY=your-google-maps-key

# Admin access (comma-separated list of allowed emails for /admin/* routes)
ADMIN_EMAILS=admin@example.com

# Backend API
BACKEND_API_URL=http://127.0.0.1:8080

# Backend API for client-side components (must be prefixed with NEXT_PUBLIC_)
NEXT_PUBLIC_API_URL=http://127.0.0.1:8080

# Optional: For production, update these values
# NEXTAUTH_URL=https://yourdomain.com
# BACKEND_API_URL=https://api.yourdomain.com
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com
